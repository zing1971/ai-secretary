# .env 範本（Hermes Agent 架構）
# ── 必填 ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=你的BotToken（向 @BotFather 申請）
TELEGRAM_CHAT_ID=你的ChatID（傳訊息給 @userinfobot 取得）
GEMINI_API_KEY=你的GeminiKey

# ── Google 服務（選用）────────────────────────────────────────
GOOGLE_SHEET_ID=你的GoogleSheetID

# ── 系統設定 ──────────────────────────────────────────────────
PORT=8080
DEBUG=False

# ── 雲端部署環境變數（VPS 部署時使用）─────────────────────────
DEPLOY_ENV=cloud
GOOGLE_CREDENTIALS_JSON=
GOOGLE_TOKEN_JSON=

# ── NotebookLM（選用）─────────────────────────────────────────
NOTEBOOK_ID_INFOSEC=
NOTEBOOK_ID_IT=
NOTEBOOK_ID_TRENDS=
