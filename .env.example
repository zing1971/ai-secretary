# .env 範本（Telegram 版）
# ── Telegram Bot ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=你的BotToken（向 @BotFather 申請）
TELEGRAM_CHAT_ID=你的ChatID（傳訊息給 @userinfobot 取得）

# ── (舊) LINE — 已停用，保留供回滾備用 ──────────────────────
# LINE_CHANNEL_ACCESS_TOKEN=你的Token
# LINE_CHANNEL_SECRET=你的Secret
# LINE_USER_ID=你的UserID

# ── Gemini AI ─────────────────────────────────────────────
GEMINI_API_KEY=你的GeminiKey

# ── Google 服務 ───────────────────────────────────────────
GOOGLE_SHEET_ID=1C6WPbZlA09Cps-aXrg3ayo8jpZlx5dIKuOGlbY76Whw
PORT=8080
DEBUG=False

# ── Pinecone 向量資料庫 ────────────────────────────────────
PINECONE_API_KEY=你的PineconeApiKey

# ── 雲端部署環境變數（選用）─────────────────────────────────
DEPLOY_ENV=cloud
GOOGLE_CREDENTIALS_JSON=
GOOGLE_TOKEN_JSON=
